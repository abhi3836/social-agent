# Agent Platform — Environment Variables
# Copy this file to .env and fill in your values.
# This file is mounted read-only into the container at /home/agent/.config/.env.example

# API Keys (rotate per your org's key rotation policy)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Proxy settings (uncomment if using egress proxy — see §7 in CLAUDE.md)
# HTTP_PROXY=http://egress-proxy:3128
# HTTPS_PROXY=http://egress-proxy:3128

# Locale
LANG=C.UTF-8
