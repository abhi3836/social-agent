# Agent Platform — Environment Variables
# Copy this file to .env and fill in your values.
# This file is mounted read-only into the container at /home/agent/.config/.env

# ── LLM ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Image Generation (choose one) ──
OPENAI_API_KEY=sk-...
# SD_API_URL=http://localhost:7860

# ── Twitter/X Developer API (required for auto-posting) ──
# Create an app at https://developer.twitter.com/ with OAuth 1.0a User Context
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
# Set to true to automatically post drafts to Twitter after generation
TWITTER_AUTO_POST=false

# ── Agent Behavior ──
POST_PLATFORMS=twitter,linkedin
SUGGESTION_COUNT=5
STYLE_REANALYZE=false
LOG_LEVEL=INFO

# ── Proxy settings (set automatically by docker-compose) ──
# HTTP_PROXY=http://egress-proxy:3128
# HTTPS_PROXY=http://egress-proxy:3128

# ── Locale ──
LANG=C.UTF-8
